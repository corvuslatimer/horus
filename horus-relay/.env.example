# Horus relay env
HOST=127.0.0.1
PORT=8787

# OpenClaw bridge (optional)
OPENCLAW_BASE_URL=http://127.0.0.1:3000
OPENCLAW_SESSION_KEY=
OPENCLAW_TOKEN=

# Telegram intel ingestion
# Primary source (WorldMonitor public feed)
TELEGRAM_PUBLIC_FEED_URL=https://worldmonitor.app/api/telegram-feed
# Enable manual channel scraping fallback if public feed fails
TELEGRAM_MANUAL_FALLBACK=true
# Poll interval for telegram intel (ms)
TELEGRAM_INTEL_POLL_MS=60000
